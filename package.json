{
  "name": "shchukin-collection-archive",
  "version": "1.0.0",
  "private": true,
  "description": "Shchukin Foundation / Shchukin Collection Archive — a provenance-sensitive scholarly archive and searchable collection index.",
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsx scripts/build-enriched.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "data:enrich": "tsx scripts/build-enriched.ts",
    "images:resolve": "tsx scripts/resolve-commons-images.ts",
    "images:cache": "tsx scripts/cache-commons-images.ts",
    "images:validate": "tsx scripts/validate-images.ts",
    "images:review": "tsx scripts/review-candidates.ts",
    "images:build": "npm run images:resolve && npm run images:cache && npm run images:validate"
  },
  "dependencies": {
    "marked": "^14.1.4",
    "next": "^15.5.19",
    "photoswipe": "^5.4.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@next/mdx": "^15.5.19",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "sharp": "^0.33.5"
  }
}
